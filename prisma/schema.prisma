// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

enum AppUserStatus {
  ACTIVE
  INVITED
  DISABLED
}

enum ClassLevel {
  IX
  X
  XI
  XII
}

model AppUser {
  id                 String        @id @default(uuid())
  supabaseAuthUserId String?       @unique
  email              String?       @unique
  role               Role
  status             AppUserStatus @default(ACTIVE)
  studentId          String?       @unique
  teacherId          String?       @unique
  fullName           String?
  phone              String?

  student Student? @relation(fields: [studentId], references: [id])
  teacher Teacher? @relation(fields: [teacherId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?
  updatedBy String?

  uploadedFiles FileAsset[] @relation("FileAssetUploader")
}

model Student {
  id            String    @id @default(uuid())
  studentCode   String    @unique
  fullName      String
  phone         String?
  guardianPhone String?
  email         String?
  joiningDate   DateTime?
  accountStatus String    @default("none") // none, invited, active, disabled

  appUser           AppUser?
  enrolments        Enrolment[]
  announcementReads StudentAnnouncementRead[]

  archivedAt DateTime?
  archivedBy String?
}

model Teacher {
  id             String  @id @default(uuid())
  displayName    String
  phone          String?
  email          String?
  bio            String?
  qualifications String?
  photoFileId    String?
  active         Boolean @default(true)
  subjects       String[] @default([])

  appUser            AppUser?
  teacherAssignments TeacherAssignment[]
  liveClassSessions  LiveClassSession[]
}

enum PermissionCapability {
  BATCH_VIEW
  BATCH_MANAGE
  MEMBERS_VIEW
  MEMBERS_MANAGE
  ATTENDANCE_VIEW
  ATTENDANCE_MANAGE
  CURRICULUM_PROGRESS_VIEW
  CURRICULUM_PROGRESS_MANAGE
  MATERIALS_VIEW
  MATERIALS_MANAGE
  HOMEWORK_VIEW
  HOMEWORK_MANAGE
  QUESTION_BANK_VIEW
  QUESTION_BANK_MANAGE
  TESTS_VIEW
  TESTS_MANAGE
  RESULTS_VIEW
  RESULTS_MANAGE
  FEES_VIEW
  FEES_MANAGE
  PAYMENTS_RECORD
  SCHEDULE_VIEW
  SCHEDULE_MANAGE
  ANNOUNCEMENTS_VIEW
  ANNOUNCEMENTS_MANAGE
}

model TeacherAssignment {
  id          String                 @id @default(uuid())
  teacherId   String
  batchId     String
  permissions PermissionCapability[]

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  createdBy  String?
  updatedBy  String?
  archivedAt DateTime?
  archivedBy String?

  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Restrict)
  batch   Batch   @relation(fields: [batchId], references: [id], onDelete: Restrict)

  @@index([teacherId])
  @@index([batchId])
}

model Board {
  id         String    @id @default(uuid())
  code       String    @unique // CBSE, CISCE
  name       String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  createdBy  String?
  updatedBy  String?
  archivedAt DateTime?
  archivedBy String?

  programmes       Programme[]
  curriculumTracks CurriculumTrack[]
}

model Programme {
  id         String    @id @default(uuid())
  boardId    String
  code       String // ICSE, ISC
  name       String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  createdBy  String?
  updatedBy  String?
  archivedAt DateTime?
  archivedBy String?

  board            Board             @relation(fields: [boardId], references: [id])
  curriculumTracks CurriculumTrack[]

  @@unique([boardId, code])
}

model Subject {
  id         String    @id @default(uuid())
  code       String    @unique // MATHEMATICS
  name       String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  createdBy  String?
  updatedBy  String?
  archivedAt DateTime?
  archivedBy String?

  curriculumTracks CurriculumTrack[]
}

model CurriculumTrack {
  id          String     @id @default(uuid())
  boardId     String
  programmeId String?
  classLevel  ClassLevel
  subjectId   String
  displayName String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  createdBy   String?
  updatedBy   String?
  archivedAt  DateTime?
  archivedBy  String?

  board      Board       @relation(fields: [boardId], references: [id])
  programme  Programme?  @relation(fields: [programmeId], references: [id])
  subject    Subject     @relation(fields: [subjectId], references: [id])
  chapters   Chapter[]
  batches    Batch[]
  enrolments Enrolment[]

  // Actually, Prisma does not natively support partial indexes yet using @@unique with WHERE.
  // We rely on custom migration to enforce:
  // 1. UNIQUE ("boardId", "classLevel", "subjectId") WHERE "programmeId" IS NULL
  // 2. UNIQUE ("boardId", "programmeId", "classLevel", "subjectId") WHERE "programmeId" IS NOT NULL

  // Only one CBSE track may exist for a given board/class/subject combination when programmeId is NULL.

  uploadReservations FileAsset[]     @relation("FileAssetTrack")
  studyMaterials     StudyMaterial[]
  homeworks          Homework[]
  tests              Test[]
  questions          Question[]
  feePlans           FeePlan[]
  announcements      Announcement[]
}

model Chapter {
  id                String    @id @default(uuid())
  curriculumTrackId String
  name              String
  displayOrder      Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  createdBy         String?
  updatedBy         String?
  archivedAt        DateTime?
  archivedBy        String?

  curriculumTrack CurriculumTrack @relation(fields: [curriculumTrackId], references: [id])
  topics          Topic[]
  studyMaterials  StudyMaterial[]
  homeworks       Homework[]
  tests           Test[]
  questions       Question[]

  @@index([curriculumTrackId])
}

model Topic {
  id           String    @id @default(uuid())
  chapterId    String
  name         String
  displayOrder Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  createdBy    String?
  updatedBy    String?
  archivedAt   DateTime?
  archivedBy   String?

  chapter        Chapter         @relation(fields: [chapterId], references: [id])
  studyMaterials StudyMaterial[]
  homeworks      Homework[]
  tests          Test[]
  questions      Question[]

  @@index([chapterId])
}

model AcademicSession {
  id         String    @id @default(uuid())
  name       String    @unique
  startsOn   DateTime?
  endsOn     DateTime?
  isActive   Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  createdBy  String?
  updatedBy  String?
  archivedAt DateTime?
  archivedBy String?

  batches            Batch[]
  enrolments         Enrolment[]
  uploadReservations FileAsset[]     @relation("FileAssetSession")
  studyMaterials     StudyMaterial[]
  homeworks          Homework[]
  tests              Test[]
  feePlans           FeePlan[]
  announcements      Announcement[]
}

model AuditLog {
  id          String   @id @default(uuid())
  actorUserId String?
  action      String
  entityType  String
  entityId    String?
  summary     String
  metadata    Json?
  createdAt   DateTime @default(now())
}

model Batch {
  id                String    @id @default(uuid())
  academicSessionId String
  curriculumTrackId String
  name              String
  capacity          Int?
  isPublic          Boolean   @default(false)
  showFeePublicly   Boolean   @default(false)
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  createdBy         String?
  updatedBy         String?
  archivedAt        DateTime?
  archivedBy        String?

  academicSession    AcademicSession     @relation(fields: [academicSessionId], references: [id])
  curriculumTrack    CurriculumTrack     @relation(fields: [curriculumTrackId], references: [id])
  schedules          BatchSchedule[]
  enrolments         Enrolment[]
  teacherAssignments TeacherAssignment[]

  // Note: We do NOT use @@unique here.
  // We use a custom migration to create: UNIQUE (academicSessionId, curriculumTrackId, name) WHERE archivedAt IS NULL

  uploadReservations FileAsset[]        @relation("FileAssetBatch")
  studyMaterials     StudyMaterial[]
  homeworks          Homework[]
  tests              Test[]
  feePlans           FeePlan[]
  announcements      Announcement[]
  liveClassSessions  LiveClassSession[]
}

model Announcement {
  id                String               @id @default(uuid())
  academicSessionId String?
  audience          AnnouncementAudience
  curriculumTrackId String?
  batchId           String?
  title             String
  content           String
  priority          AnnouncementPriority @default(NORMAL)

  publishedAt DateTime?
  expiresAt   DateTime?
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  createdBy  String?
  updatedBy  String?
  archivedBy String?

  academicSession AcademicSession? @relation(fields: [academicSessionId], references: [id])
  curriculumTrack CurriculumTrack? @relation(fields: [curriculumTrackId], references: [id])
  batch           Batch?           @relation(fields: [batchId], references: [id])

  readReceipts StudentAnnouncementRead[]

  @@index([audience])
  @@index([publishedAt])
  @@index([expiresAt])
  @@index([curriculumTrackId])
  @@index([batchId])
}

model StudentAnnouncementRead {
  id             String   @id @default(uuid())
  studentId      String
  announcementId String
  readAt         DateTime @default(now())

  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  @@unique([studentId, announcementId])
  @@index([studentId])
  @@index([announcementId])
}

model BatchSchedule {
  id             String   @id @default(uuid())
  batchId        String
  dayOfWeek      Int
  startTime      String
  endTime        String
  roomOrLocation String?
  liveClassUrl   String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  batch             Batch              @relation(fields: [batchId], references: [id], onDelete: Cascade)
  liveClassSessions LiveClassSession[]
}

model Enrolment {
  id                String    @id @default(uuid())
  studentId         String
  academicSessionId String
  curriculumTrackId String
  batchId           String?
  joiningDate       DateTime
  status            String    @default("active") // active, withdrawn, completed, suspended
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  createdBy         String?
  updatedBy         String?
  archivedAt        DateTime?
  archivedBy        String?

  student         Student         @relation(fields: [studentId], references: [id])
  academicSession AcademicSession @relation(fields: [academicSessionId], references: [id])
  curriculumTrack CurriculumTrack @relation(fields: [curriculumTrackId], references: [id])
  batch           Batch?          @relation(fields: [batchId], references: [id])

  feeAssignments StudentFeeAssignment[]

  // Note: We do NOT use @@unique here.
  // We use a custom migration to create: UNIQUE (studentId, academicSessionId, curriculumTrackId) WHERE archivedAt IS NULL
}

model FeePlan {
  id                String           @id @default(uuid())
  academicSessionId String
  curriculumTrackId String
  batchId           String?
  name              String
  description       String?
  totalAmount       Decimal          @db.Decimal(10, 2)
  frequency         FeePlanFrequency
  showPublicly      Boolean          @default(false)
  isActive          Boolean          @default(true)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  createdBy         String?
  updatedBy         String?
  archivedAt        DateTime?
  archivedBy        String?

  academicSession AcademicSession @relation(fields: [academicSessionId], references: [id])
  curriculumTrack CurriculumTrack @relation(fields: [curriculumTrackId], references: [id])
  batch           Batch?          @relation(fields: [batchId], references: [id])

  instalments    FeePlanInstallment[]
  feeAssignments StudentFeeAssignment[]

  @@index([academicSessionId])
  @@index([curriculumTrackId])
  @@index([batchId])
  @@index([frequency])
  @@index([isActive])
}

model FeePlanInstallment {
  id            String    @id @default(uuid())
  feePlanId     String
  label         String
  dueOffsetDays Int?
  dueDate       DateTime?
  amount        Decimal   @db.Decimal(10, 2)
  displayOrder  Int       @default(0)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  feePlan FeePlan         @relation(fields: [feePlanId], references: [id], onDelete: Cascade)
  feeDues StudentFeeDue[]

  @@index([feePlanId])
}

model StudentFeeAssignment {
  id                  String              @id @default(uuid())
  enrolmentId         String
  feePlanId           String
  assignedTotalAmount Decimal             @db.Decimal(10, 2)
  startsOn            DateTime
  endsOn              DateTime?
  status              FeeAssignmentStatus @default(ACTIVE)
  archivedAt          DateTime?
  archivedBy          String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  createdBy           String?
  updatedBy           String?

  enrolment Enrolment       @relation(fields: [enrolmentId], references: [id])
  feePlan   FeePlan         @relation(fields: [feePlanId], references: [id])
  dues      StudentFeeDue[]

  // Note: We do NOT use @@unique here.
  // We use a custom migration to create: UNIQUE (enrolmentId, feePlanId) WHERE archivedAt IS NULL AND status = 'ACTIVE'

  @@index([enrolmentId])
  @@index([feePlanId])
  @@index([status])
}

model StudentFeeDue {
  id                   String       @id @default(uuid())
  feeAssignmentId      String
  feePlanInstallmentId String?
  label                String
  dueDate              DateTime
  amountDue            Decimal      @db.Decimal(10, 2)
  amountWaived         Decimal      @default(0) @db.Decimal(10, 2)
  status               FeeDueStatus @default(PENDING)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  feeAssignment      StudentFeeAssignment @relation(fields: [feeAssignmentId], references: [id], onDelete: Cascade)
  feePlanInstallment FeePlanInstallment?  @relation(fields: [feePlanInstallmentId], references: [id])

  @@index([feeAssignmentId])
  @@index([feePlanInstallmentId])
  @@index([status])
  @@index([dueDate])
}

enum FileAssetStorageAccessClass {
  PUBLIC
  PRIVATE
}

enum FileAssetLifecycleState {
  PENDING
  ACTIVE
  ARCHIVED
  ABANDONED
}

enum FileUploadUsageCategory {
  STUDY_MATERIAL
  HOMEWORK
  TEST
  PUBLIC_ASSET
}

enum FileUploadScope {
  BATCH
  CURRICULUM_TRACK
}

enum StudyMaterialResourceType {
  DOCUMENT
  PRESENTATION
  IMAGE
  LINK
  TEXT
}

enum StudyMaterialVisibility {
  CURRICULUM_TRACK
  BATCH
}

enum StudyMaterialLifecycleState {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum HomeworkLifecycleState {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum TestType {
  CHAPTER_TEST
  UNIT_TEST
  FULL_SYLLABUS_TEST
}

enum TestLifecycleState {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum QuestionFormat {
  PLAIN_TEXT
  MARKDOWN_LATEX
}

enum QuestionType {
  SHORT_ANSWER
  LONG_ANSWER
  MCQ
  NUMERICAL
  PROOF
  ASSERTION_REASON
  CASE_STUDY
  OTHER
}

enum QuestionDifficulty {
  EASY
  MEDIUM
  HARD
}

enum FeePlanFrequency {
  MONTHLY
  QUARTERLY
  YEARLY
  CUSTOM
}

enum PaymentMethod {
  CASH
  UPI
  BANK_TRANSFER
  CHEQUE
  OTHER
}

enum FeeDueStatus {
  PENDING
  PARTIALLY_PAID
  PAID
  WAIVED
  CANCELLED
  OVERDUE
}

enum FeeAssignmentStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum AnnouncementAudience {
  PUBLIC
  ALL_STUDENTS
  CURRICULUM_TRACK
  BATCH
}

enum AnnouncementPriority {
  NORMAL
  HIGH
  URGENT
}

enum ImportType {
  STUDENT
  QUESTION
}

enum ImportJobStatus {
  PENDING
  VALIDATING
  READY
  PROCESSING
  COMPLETED
  COMPLETED_WITH_ERRORS
  FAILED
}

enum ImportRowStatus {
  PENDING
  VALID
  WARNING
  ERROR
}

model FileAsset {
  id                 String                      @id @default(uuid())
  bucket             String
  storageKey         String                      @unique
  originalFilename   String
  mimeType           String
  sizeBytes          Int
  storageAccessClass FileAssetStorageAccessClass
  lifecycleState     FileAssetLifecycleState
  usageCategory      FileUploadUsageCategory
  uploadScope        FileUploadScope

  targetBatchId   String?
  targetSessionId String?
  targetTrackId   String?

  storageDeletedAt DateTime?
  uploadedById     String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  targetBatch   Batch?           @relation("FileAssetBatch", fields: [targetBatchId], references: [id])
  targetSession AcademicSession? @relation("FileAssetSession", fields: [targetSessionId], references: [id])
  targetTrack   CurriculumTrack? @relation("FileAssetTrack", fields: [targetTrackId], references: [id])
  uploadedBy    AppUser          @relation("FileAssetUploader", fields: [uploadedById], references: [id])

  studyMaterials StudyMaterial[]
  homeworks      Homework[]      @relation("FileAssetHomework")
  tests          Test[]          @relation("FileAssetTest")
  testimonials   Testimonial[]   @relation("TestimonialPhoto")
  galleryItems   GalleryItem[]
}

model StudyMaterial {
  id                String  @id @default(uuid())
  academicSessionId String
  curriculumTrackId String
  batchId           String?
  chapterId         String?
  topicId           String?

  title           String
  description     String?
  resourceType    StudyMaterialResourceType
  fileAssetId     String?
  externalLinkUrl String?
  textContent     String?

  visibility     StudyMaterialVisibility
  lifecycleState StudyMaterialLifecycleState
  featured       Boolean                     @default(false)

  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  archivedAt  DateTime?

  createdBy  String?
  updatedBy  String?
  archivedBy String?

  academicSession AcademicSession @relation(fields: [academicSessionId], references: [id])
  curriculumTrack CurriculumTrack @relation(fields: [curriculumTrackId], references: [id])
  batch           Batch?          @relation(fields: [batchId], references: [id])
  chapter         Chapter?        @relation(fields: [chapterId], references: [id])
  topic           Topic?          @relation(fields: [topicId], references: [id])
  fileAsset       FileAsset?      @relation(fields: [fileAssetId], references: [id])

  @@index([academicSessionId, curriculumTrackId, visibility, lifecycleState])
  @@index([batchId, lifecycleState])
  @@index([visibility, lifecycleState, featured])
}

model SystemSequence {
  id        String   @id
  lastValue Int
  updatedAt DateTime @updatedAt
}

model HomepageSection {
  id           String   @id @default(uuid())
  sectionKey   String   @unique
  isVisible    Boolean  @default(true)
  displayOrder Int      @default(0)
  title        String?
  locked       Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  updatedBy    String?
}

model WhyChooseUsItem {
  id           String   @id @default(uuid())
  title        String
  description  String
  iconName     String?
  displayOrder Int      @default(0)
  isPublished  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model MethodologyStep {
  id           String   @id @default(uuid())
  title        String
  description  String
  stepNumber   Int
  displayOrder Int      @default(0)
  isPublished  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Testimonial {
  id                 String      @id @default(uuid())
  studentName        String
  designation        String?
  studentClass       ClassLevel?
  batch              String?
  year               Int?
  studentPhotoFileId String?
  message            String
  featured           Boolean     @default(false)
  displayOrder       Int         @default(0)
  isPublished        Boolean     @default(false)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  studentPhoto FileAsset? @relation("TestimonialPhoto", fields: [studentPhotoFileId], references: [id])
}

model GalleryItem {
  id           String   @id @default(uuid())
  caption      String?
  category     String?
  fileAssetId  String
  displayOrder Int      @default(0)
  isPublished  Boolean  @default(false)
  createdAt    DateTime @default(now())

  fileAsset FileAsset @relation(fields: [fileAssetId], references: [id])
}

model FAQ {
  id           String   @id @default(uuid())
  question     String
  answer       String
  category     String?
  displayOrder Int      @default(0)
  isPublished  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model PerformanceMetric {
  id           String   @id @default(uuid())
  label        String
  value        String
  displayOrder Int      @default(0)
  isPublished  Boolean  @default(false)
  createdAt    DateTime @default(now())
}

model ImportJob {
  id                String          @id @default(uuid())
  importType        ImportType
  originalFilename  String
  fileSize          Int             @default(0)
  sourceStoragePath String?
  status            ImportJobStatus @default(PENDING)
  totalRows         Int             @default(0)
  validRows         Int             @default(0)
  warningRows       Int             @default(0)
  errorRows         Int             @default(0)
  importedRows      Int             @default(0)
  failedRows        Int             @default(0)
  skippedRows       Int             @default(0)
  startedAt         DateTime?
  completedAt       DateTime?
  errorSummary      String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  createdBy         String?
  updatedBy         String?

  rows ImportRow[]

  @@index([createdBy])
  @@index([importType])
  @@index([status])
  @@index([createdAt])
}

model ImportRow {
  id          String          @id @default(uuid())
  importJobId String
  rowNumber   Int
  status      ImportRowStatus @default(PENDING)
  data        Json
  errors      Json?
  warnings    Json?

  importJob ImportJob @relation(fields: [importJobId], references: [id], onDelete: Cascade)

  @@index([importJobId])
  @@index([importJobId, status])
}

model Homework {
  id                String  @id @default(uuid())
  academicSessionId String
  curriculumTrackId String
  batchId           String
  chapterId         String?
  topicId           String?

  title       String
  description String?
  fileAssetId String?

  assignedDate DateTime
  dueDate      DateTime

  lifecycleState HomeworkLifecycleState @default(DRAFT)

  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  archivedAt  DateTime?

  createdBy  String?
  updatedBy  String?
  archivedBy String?

  academicSession AcademicSession @relation(fields: [academicSessionId], references: [id])
  curriculumTrack CurriculumTrack @relation(fields: [curriculumTrackId], references: [id])
  batch           Batch           @relation(fields: [batchId], references: [id])
  chapter         Chapter?        @relation(fields: [chapterId], references: [id])
  topic           Topic?          @relation(fields: [topicId], references: [id])
  fileAsset       FileAsset?      @relation("FileAssetHomework", fields: [fileAssetId], references: [id])

  @@index([academicSessionId, curriculumTrackId, lifecycleState])
  @@index([batchId, lifecycleState])
}

model Test {
  id                  String             @id @default(uuid())
  academicSessionId   String
  curriculumTrackId   String
  batchId             String
  chapterId           String?
  topicId             String?
  title               String
  description         String?
  testType            TestType
  testDate            DateTime
  durationMinutes     Int?
  maximumMarks        Int
  syllabusDescription String?
  questionPaperFileId String?
  lifecycleState      TestLifecycleState @default(DRAFT)
  publishedAt         DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  archivedAt          DateTime?
  createdBy           String?
  updatedBy           String?
  archivedBy          String?

  academicSession AcademicSession @relation(fields: [academicSessionId], references: [id])
  curriculumTrack CurriculumTrack @relation(fields: [curriculumTrackId], references: [id])
  batch           Batch           @relation(fields: [batchId], references: [id])
  chapter         Chapter?        @relation(fields: [chapterId], references: [id])
  topic           Topic?          @relation(fields: [topicId], references: [id])
  fileAsset       FileAsset?      @relation("FileAssetTest", fields: [questionPaperFileId], references: [id])

  @@index([academicSessionId, curriculumTrackId, lifecycleState])
  @@index([batchId, lifecycleState])
}

model Question {
  id                String             @id @default(uuid())
  curriculumTrackId String
  chapterId         String
  topicId           String?
  questionText      String
  questionFormat    QuestionFormat     @default(MARKDOWN_LATEX)
  questionType      QuestionType
  difficulty        QuestionDifficulty
  marks             Int
  answerText        String?
  solutionText      String?
  imageFileId       String?
  source            String?
  academicRelevance String?
  archivedAt        DateTime?
  archivedBy        String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  createdBy         String?
  updatedBy         String?

  curriculumTrack CurriculumTrack @relation(fields: [curriculumTrackId], references: [id])
  chapter         Chapter         @relation(fields: [chapterId], references: [id])
  topic           Topic?          @relation(fields: [topicId], references: [id])

  @@index([curriculumTrackId])
  @@index([chapterId])
  @@index([topicId])
  @@index([curriculumTrackId, questionType, difficulty])
}

model SiteSettings {
  id                     String   @id @default(uuid())
  instituteName          String
  tagline                String?
  phone                  String?
  whatsappNumber         String?
  email                  String?
  address                String?
  landmark               String?
  mapUrl                 String?
  openingHours           String?
  logoFileId             String?
  faviconFileId          String?
  defaultTitle           String?
  defaultDescription     String?
  ogImageFileId          String?
  socialLinks            Json?
  heroHeadline           String?
  heroSubheadline        String?
  heroCtaText            String?
  heroCtaTarget          String?
  feeDisplayEnabled      Boolean  @default(true)
  admissionsOpen         Boolean  @default(true)
  resourcesEnabled       Boolean  @default(true)
  resourcesSearchEnabled Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  createdBy              String?
  updatedBy              String?

  @@index([id])
}

enum LiveClassSessionStatus {
  SCHEDULED
  CANCELLED
  COMPLETED
}

model LiveClassSession {
  id                 String                 @id @default(uuid())
  batchId            String
  teacherId          String
  batchScheduleId    String?
  title              String
  scheduledStartTime DateTime
  scheduledEndTime   DateTime
  meetingUrl         String?
  status             LiveClassSessionStatus @default(SCHEDULED)
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  createdBy          String?
  updatedBy          String?

  batch         Batch          @relation(fields: [batchId], references: [id])
  teacher       Teacher        @relation(fields: [teacherId], references: [id])
  batchSchedule BatchSchedule? @relation(fields: [batchScheduleId], references: [id])

  @@index([batchId])
  @@index([teacherId])
  @@index([scheduledStartTime])
  @@index([status])
  @@index([batchId, scheduledStartTime])
  @@index([teacherId, scheduledStartTime])
}
